# Database
DB_HOST=<db-host>
DB_PORT=5432
DB_NAME=<db-name>
DB_USER=<db-user>
DB_PASSWORD=<db-password>

# Server
PORT=3001
NODE_ENV=development

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173

# JWT
JWT_SECRET=<generate-a-strong-random-secret-here>
JWT_EXPIRES_IN=8h
