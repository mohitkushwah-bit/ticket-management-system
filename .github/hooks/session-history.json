{
  "hooks": {
    "Stop": [
      {
        "type": "command",
        "command": "./scripts/hooks/save-session-history.sh",
        "timeout": 15
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "./scripts/hooks/log-prompt.sh",
        "timeout": 10
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "./scripts/hooks/log-response.sh",
        "timeout": 10
      }
    ]
  }
}
